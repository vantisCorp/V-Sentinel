{
  "dashboard": {
    "title": "V-Sentinel PQC Overview",
    "uid": "pqc-overview",
    "tags": ["pqc", "security", "v-sentinel"],
    "timezone": "browser",
    "refresh": "30s",
    "panels": [
      {
        "title": "PQC Services Status",
        "type": "stat",
        "gridPos": {"h": 4, "w": 24, "x": 0, "y": 0},
        "targets": [
          {
            "expr": "sum(up{job=~&quot;pqc-.*&quot;})",
            "legendFormat": "Services Up"
          },
          {
            "expr": "count(up{job=~&quot;pqc-.*&quot;} == 0)",
            "legendFormat": "Services Down"
          }
        ],
        "options": {
          "colorMode": "background",
          "graphMode": "none"
        }
      },
      {
        "title": "TLS Handshake Latency (p95)",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(pqc_tls_handshake_duration_seconds_bucket[5m]))",
            "legendFormat": "{{ service }}"
          }
        ],
        "yaxes": [
          {"format": "s", "label": "Latency"},
          {"format": "short"}
        ],
        "alert": {
          "conditions": [
            {
              "evaluator": {"type": "gt", "params": [0.1]},
              "operator": {"type": "and"},
              "query": {"params": ["A", "5m", "now"]},
              "reducer": {"type": "avg"}
            }
          ],
          "message": "TLS handshake latency exceeded 100ms threshold",
          "name": "PQC Gateway Latency Alert"
        }
      },
      {
        "title": "Key Operations Rate",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
        "targets": [
          {
            "expr": "rate(pqc_key_generation_total[5m])",
            "legendFormat": "Key Generation"
          },
          {
            "expr": "rate(pqc_key_rotation_total[5m])",
            "legendFormat": "Key Rotation"
          },
          {
            "expr": "rate(pqc_encryption_operations_total[5m])",
            "legendFormat": "Encryption"
          }
        ],
        "yaxes": [
          {"format": "ops", "label": "Operations/sec"},
          {"format": "short"}
        ]
      },
      {
        "title": "VPN Tunnel Status",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 0, "y": 12},
        "targets": [
          {
            "expr": "sum(pqc_vpn_active_tunnels)",
            "legendFormat": "Active Tunnels"
          }
        ],
        "options": {
          "colorMode": "value",
          "graphMode": "area"
        }
      },
      {
        "title": "Messages Processed",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 6, "y": 12},
        "targets": [
          {
            "expr": "rate(pqc_messaging_messages_total[5m])",
            "legendFormat": "msg/sec"
          }
        ],
        "options": {
          "colorMode": "value",
          "graphMode": "area"
        }
      },
      {
        "title": "Certificate Expiration",
        "type": "gauge",
        "gridPos": {"h": 4, "w": 6, "x": 12, "y": 12},
        "targets": [
          {
            "expr": "min(pqc_certificate_days_until_expiry)",
            "legendFormat": "Days until expiry"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "red", "value": 0},
                {"color": "yellow", "value": 7},
                {"color": "green", "value": 30}
              ]
            },
            "unit": "d"
          }
        }
      },
      {
        "title": "Key Age Distribution",
        "type": "gauge",
        "gridPos": {"h": 4, "w": 6, "x": 18, "y": 12},
        "targets": [
          {
            "expr": "avg(pqc_key_age_days)",
            "legendFormat": "Average Key Age"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "green", "value": 0},
                {"color": "yellow", "value": 60},
                {"color": "red", "value": 80}
              ]
            },
            "unit": "d"
          }
        }
      },
      {
        "title": "Encryption Performance by Algorithm",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
        "targets": [
          {
            "expr": "histogram_quantile(0.50, rate(pqc_encryption_duration_seconds_bucket{algorithm=&quot;kyber1024&quot;}[5m]))",
            "legendFormat": "Kyber1024 p50"
          },
          {
            "expr": "histogram_quantile(0.95, rate(pqc_encryption_duration_seconds_bucket{algorithm=&quot;kyber1024&quot;}[5m]))",
            "legendFormat": "Kyber1024 p95"
          },
          {
            "expr": "histogram_quantile(0.50, rate(pqc_encryption_duration_seconds_bucket{algorithm=&quot;dilithium5&quot;}[5m]))",
            "legendFormat": "Dilithium5 p50"
          },
          {
            "expr": "histogram_quantile(0.95, rate(pqc_encryption_duration_seconds_bucket{algorithm=&quot;dilithium5&quot;}[5m]))",
            "legendFormat": "Dilithium5 p95"
          }
        ],
        "yaxes": [
          {"format": "s", "label": "Duration"},
          {"format": "short"}
        ]
      },
      {
        "title": "Error Rate",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
        "targets": [
          {
            "expr": "rate(pqc_gateway_errors_total[5m])",
            "legendFormat": "Gateway Errors"
          },
          {
            "expr": "rate(pqc_vpn_errors_total[5m])",
            "legendFormat": "VPN Errors"
          },
          {
            "expr": "rate(pqc_messaging_errors_total[5m])",
            "legendFormat": "Messaging Errors"
          }
        ],
        "yaxes": [
          {"format": "errors/sec", "label": "Error Rate"},
          {"format": "short"}
        ]
      },
      {
        "title": "Resource Utilization",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 24},
        "targets": [
          {
            "expr": "rate(container_cpu_usage_seconds_total{container=~&quot;pqc-.*&quot;}[5m])",
            "legendFormat": "{{ container }} CPU"
          },
          {
            "expr": "container_memory_usage_bytes{container=~&quot;pqc-.*&quot;} / 1024 / 1024 / 1024",
            "legendFormat": "{{ container }} Memory (GB)"
          }
        ]
      },
      {
        "title": "Quantum Threat Score",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 24},
        "targets": [
          {
            "expr": "quantum_threat_score",
            "legendFormat": "Threat Score"
          },
          {
            "expr": "rate(quantum_threat_indicators_total[1h])",
            "legendFormat": "Indicators/hr"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "green", "value": 0},
                {"color": "yellow", "value": 0.5},
                {"color": "red", "value": 0.7}
              ]
            }
          }
        }
      },
      {
        "title": "Compliance Status",
        "type": "table",
        "gridPos": {"h": 6, "w": 24, "x": 0, "y": 32},
        "targets": [
          {
            "expr": "pqc_compliance_nist",
            "legendFormat": "NIST Compliance",
            "format": "table"
          },
          {
            "expr": "pqc_compliance_cnsa2",
            "legendFormat": "CNSA 2.0 Compliance",
            "format": "table"
          },
          {
            "expr": "pqc_hybrid_mode_enabled",
            "legendFormat": "Hybrid Mode",
            "format": "table"
          }
        ],
        "transformations": [
          {
            "id": "merge",
            "options": {}
          }
        ]
      }
    ],
    "schemaVersion": 38,
    "version": 1,
    "time": {
      "from": "now-6h",
      "to": "now"
    },
    "timepicker": {
      "refresh_intervals": ["10s", "30s", "1m", "5m", "15m", "30m", "1h", "2h", "1d"]
    }
  }
}