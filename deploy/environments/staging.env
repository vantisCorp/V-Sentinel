# V-Sentinel Staging Environment Configuration
# PQC-specific settings for staging deployment

# General Settings
ENVIRONMENT=staging
REGION=us-east-1
PROJECT=v-sentinel

# Docker Registry
DOCKER_REGISTRY=docker.io/v-sentinel

# Terraform State
TERRAFORM_STATE_BUCKET=v-sentinel-terraform-state-staging
TERRAFORM_STATE_KEY=v-sentinel/staging/terraform.tfstate

# PQC Configuration
PQC_ENABLED=true
PQC_HYBRID_MODE=true
PQC_KEM_ALGORITHM=kyber1024
PQC_SIGNATURE_ALGORITHM=dilithium5
PQC_FALLBACK_TO_CLASSICAL=true

# PQC Security Levels
PQC_MIN_SECURITY_LEVEL=5
PQC_KEY_ROTATION_DAYS=90
PQC_CERT_VALIDITY_DAYS=365

# Database Configuration
DB_USER=v_sentinel
DB_NAME=v_sentinel_pqc
DB_PORT=5432

# Network Configuration
GATEWAY_PORT=8443
VPN_PORT=1194
MESSAGING_PORT=5671

# Kubernetes Configuration
KUBERNETES_CLUSTER=v-sentinel-staging
KUBERNETES_NAMESPACE=v-sentinel-staging

# Monitoring Configuration
PROMETHEUS_RETENTION=15d
GRAFANA_ADMIN_USER=admin

# Security Configuration
HSM_ENABLED=false
HSM_ENDPOINT=
HSM_PARTITION=

# Feature Flags
ENABLE_QUANTUM_THREAT_DETECTION=true
ENABLE_AUTOMATIC_KEY_ROTATION=true
ENABLE_PERFORMANCE_MONITORING=true
ENABLE_SECURITY_LOGGING=true