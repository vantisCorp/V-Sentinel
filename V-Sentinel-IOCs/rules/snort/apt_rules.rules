# V-Sentinel Snort Rules - APT Groups
# Version: 1.0.0
# Author: V-Sentinel Security Research
# Date: 2026-01-15

# ============================================================================
# APT29 (Cozy Bear) Detection Rules
# ============================================================================

# SolarWinds Sunburst C2 Traffic
alert tcp $HOME_NET any -> 185.141.63.22 443 (msg:"V-Sentinel APT29 SolarWinds Sunburst C2 Traffic"; flow:established,to_server; content:"|50 4F 53 54 20|"; depth:4; content:"/api/v1/updates"; http.uri; content:"User-Agent:"; content:"SolarWinds.Orion"; http.header; metadata:impact critical, service https; reference:url,attack.mitre.org/groups/G0016/; sid:20260001; rev:1;)

# SolarWinds Sunburst DNS Tunneling
alert udp $HOME_NET any -> any 53 (msg:"V-Sentinel APT29 SolarWinds DNS Tunneling"; content:"|01 00 00 01 00 00 00 00 00 00|"; depth:10; content:"avsvmcloud"; dns_query; content:"|00 10 00 01|"; distance:0; metadata:impact high, service dns; reference:url,attack.mitre.org/groups/G0016/; sid:20260002; rev:1;)

# Teardrop Lateral Movement
alert tcp $HOME_NET any -> $HOME_NET 445 (msg:"V-Sentinel APT29 Teardrop Lateral Movement SMB"; flow:established,to_server; content:"|FF 53 4D 42|"; depth:4; content:"|00 00 00 00|"; offset:4; content:"|A2 00 00 00|"; distance:0; pcre:"/\x00\x00\x00\x00\x00\x00\x00\x00\xA2\x00\x00\x00/R"; metadata:impact high, service netbios-ssn; reference:url,attack.mitre.org/groups/G0016/; sid:20260003; rev:1;)

# ============================================================================
# Lazarus Group Detection Rules
# ============================================================================

# AppleJeus C2 Traffic
alert tcp $HOME_NET any -> 103.253.145.218 443 (msg:"V-Sentinel Lazarus AppleJeus C2 Traffic"; flow:established,to_server; content:"|50 4F 53 54 20|"; depth:4; content:"/api/v2/check"; http.uri; content:"User-Agent:"; content:"CryptoTraderPro"; http.header; metadata:impact critical, service https; reference:url,attack.mitre.org/groups/G0032/; sid:20260004; rev:1;)

# Manuscrypt Data Exfiltration
alert tcp $HOME_NET any -> 185.220.101.12 8443 (msg:"V-Sentinel Lazarus Manuscrypt Data Exfiltration"; flow:established,to_server; content:"|50 4F 53 54 20|"; depth:4; content:"/api/exfil"; http.uri; content:"Content-Type:"; content:"application/octet-stream"; http.header; metadata:impact high, service https; reference:url,attack.mitre.org/groups/G0032/; sid:20260005; rev:1;)

# WannaCry EternalBlue Exploit
alert tcp $EXTERNAL_NET any -> $HOME_NET 445 (msg:"V-Sentinel Lazarus WannaCry EternalBlue Exploit"; flow:to_server,established; content:"|FF 53 4D 42|"; depth:4; byte_test:4,>,0,2,relative; pcre:"/\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\xFF\xFE/R"; metadata:impact critical, service netbios-ssn; reference:url,attack.mitre.org/groups/G0032/; sid:20260006; rev:1;)

# Crypto Exchange Phishing
alert tcp $HOME_NET any -> any 443 (msg:"V-Sentinel Lazarus Crypto Exchange Phishing"; flow:established,to_server; content:"GET"; http.method; content:".onion"; http.uri; pcre:"/(?:crypto|trading|exchange|wallet|bitcoin|ethereum|ripple)/Ri"; metadata:impact high, service https; reference:url,attack.mitre.org/groups/G0032/; sid:20260007; rev:1;)

# ============================================================================
# Generic APT Detection Rules
# ============================================================================

# PowerShell Encoded Command Execution
alert tcp $HOME_NET any -> $HOME_NET any (msg:"V-Sentinel APT PowerShell Encoded Command"; flow:established; content:"powershell.exe"; depth:14; content:"-EncodedCommand"; distance:0; pcre:"/\-EncodedCommand\s+[A-Za-z0-9+\/=]{50,}/R"; metadata:impact medium; reference:url,attack.mitre.org/techniques/T1059/006/; sid:20260008; rev:1;)

# Credential Dumping LSASS Access
alert tcp $HOME_NET any -> $HOME_NET 135 (msg:"V-Sentinel APT LSASS Memory Access via RPC"; flow:established,to_server; content:"|5A 00 00 00|"; depth:4; content:"|FF FF FF FF|"; distance:0; pcre:"/\x00\x00\x00\x5A\xFF\xFF\xFF\xFF/R"; metadata:impact high, service msrpc; reference:url,attack.mitre.org/techniques/T1003/; sid:20260009; rev:1;)

# Lateral Movement PSExec
alert tcp $HOME_NET any -> $HOME_NET 445 (msg:"V-Sentinel APT PSExec Lateral Movement"; flow:established,to_server; content:"|FF 53 4D 42|"; depth:4; content:"|5C 50 53 45 78 65 63 5C|"; distance:0; content:"|00 00 00 00|"; distance:0; pcre:"/\x00\x00\x00\x00\x00\x00\x00\x00\x5C\x50\x53\x45\x78\x65\x63\x5C/R"; metadata:impact high, service netbios-ssn; reference:url,attack.mitre.org/techniques/T1021/; sid:20260010; rev:1;)

# Data Exfiltration Large POST
alert tcp $HOME_NET any -> $EXTERNAL_NET 443 (msg:"V-Sentinel APT Large Data Exfiltration POST"; flow:established,to_server; content:"POST"; http.method; content:"Content-Length:"; http.header; pcre:"/Content-Length:\s*[0-9]{6,}/R"; threshold:type both,track by_src,count 5,seconds 60; metadata:impact high, service https; reference:url,attack.mitre.org/techniques/T1041/; sid:20260011; rev:1;)

# DNS Tunneling Anomaly
alert udp $HOME_NET any -> any 53 (msg:"V-Sentinel APT DNS Tunneling High Volume"; content:"|01 00 00 01 00 00 00 00 00 00|"; depth:10; threshold:type both,track by_src,count 100,seconds 60; metadata:impact high, service dns; reference:url,attack.mitre.org/techniques/T1071/004/; sid:20260012; rev:1;)

# ============================================================================
# Specific Domain/Host Detection
