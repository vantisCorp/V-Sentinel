alert tcp $HOME_NET any -> any any (msg:"V-Sentinel Lazarus Known Malicious Domain"; flow:established,to_server; content:"Host:"; http.header; content:"update-service.mobi"; fast_pattern; distance:0; metadata:impact critical, service http; reference:url,attack.mitre.org/groups/G0032/; sid:20260015; rev:1;)

alert tcp $HOME_NET any -> any any (msg:"V-Sentinel Lazarus Known Malicious Domain"; flow:established,to_server; content:"Host:"; http.header; content:"crypto-trader-pro.net"; fast_pattern; distance:0; metadata:impact high, service http; reference:url,attack.mitre.org/groups/G0032/; sid:20260016; rev:1;)

# Known Malicious IPs - APT29
alert tcp $HOME_NET any -> 185.141.63.22 443 (msg:"V-Sentinel APT29 Known Malicious IP"; flow:established,to_server; metadata:impact critical, service https; reference:url,attack.mitre.org/groups/G0016/; sid:20260017; rev:1;)

alert tcp $HOME_NET any -> 52.183.126.208 443 (msg:"V-Sentinel APT29 Known Malicious IP"; flow:established,to_server; metadata:impact critical, service https; reference:url,attack.mitre.org/groups/G0016/; sid:20260018; rev:1;)

# Known Malicious IPs - Lazarus
alert tcp $HOME_NET any -> 103.253.145.218 443 (msg:"V-Sentinel Lazarus Known Malicious IP"; flow:established,to_server; metadata:impact critical, service https; reference:url,attack.mitre.org/groups/G0032/; sid:20260019; rev:1;)

alert tcp $HOME_NET any -> 185.220.101.12 8443 (msg:"V-Sentinel Lazarus Known Malicious IP"; flow:established,to_server; metadata:impact high, service https; reference:url,attack.mitre.org/groups/G0032/; sid:20260020; rev:1;)

