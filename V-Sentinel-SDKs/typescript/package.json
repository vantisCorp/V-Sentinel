{
  "name": "@vantis/v-sentinel-sdk",
  "version": "1.0.0",
  "description": "Official TypeScript SDK for the V-Sentinel security operations platform",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "v-sentinel",
    "vantis",
    "security",
    "threat-intelligence",
    "siem",
    "soc",
    "incident-response",
    "detection",
    "sdk",
    "api-client"
  ],
  "author": "Vantis AI",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vantis-ai/v-sentinel-sdks.git",
    "directory": "typescript"
  },
  "bugs": {
    "url": "https://github.com/vantis-ai/v-sentinel-sdks/issues"
  },
  "homepage": "https://docs.vantis.ai/sdks/typescript",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "axios": "^1.6.7",
    "axios-retry": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.16",
    "@typescript-eslint/eslint-plugin": "^7.0.1",
    "@typescript-eslint/parser": "^7.0.1",
    "eslint": "^8.56.0",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3",
    "vitest": "^1.2.2"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}